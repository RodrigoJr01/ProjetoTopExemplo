<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Exemplo RodrigoJr</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Fonte moderna -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap"
          rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjetoExemploTop.styles.css" asp-append-version="true" />

    <style>

            html, body {
                height: 100%;
            }

            body {
                font-family: 'Poppins', sans-serif;
                background: #f4f7fc;

                display: flex;
                flex-direction: column;
            }

            main {
                flex: 1;
            }

            .navbar-custom {
                background: linear-gradient(90deg, #0f172a, #1e293b);
                padding: 18px 0;
                box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            }

            .navbar-brand-custom {
                font-size: 2rem;
                font-weight: 700;
                color: white !important;
            }

            .nav-link-custom {
                color: #e2e8f0 !important;
                font-size: 1.1rem;
                margin: 0 15px;
                transition: 0.3s;
            }

            .nav-link-custom:hover {
                color: #38bdf8 !important;
            }

            .btn-login-custom {
                padding: 12px 35px;
                font-size: 1.1rem;
                font-weight: bold;
                border-radius: 12px;
                background: #2563eb;
                border: none;
                transition: 0.3s;
            }

            .btn-login-custom:hover {
                background: #1d4ed8;
                transform: scale(1.05);
            }

            footer {
                margin-top: auto;
            }

    </style>
</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">

            <div class="container">

                <!-- MENU CENTRALIZADO -->
                <div class="collapse navbar-collapse justify-content-center">

                    <!-- ESQUERDA -->
                    <ul class="navbar-nav align-items-center">

                        <li class="nav-item">
                            <a class="nav-link nav-link-custom"
                                   asp-controller="Home"
                                   asp-action="Index">
                                <i class="bi bi-house-door-fill"></i> Home
                            </a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom"
                                       asp-controller="Produto"
                                       asp-action="Index">
                                    <i class="bi bi-box-seam"></i> Estoque
                                </a>
                            </li>
                        }

                    </ul>

                    <!-- TITULO NO MEIO -->
                    <a class="navbar-brand navbar-brand-custom mx-5"
                           asp-controller="Home"
                           asp-action="Index">

                        <i class="bi bi-shop me-2"></i>
                        ProjetoExemploTop

                    </a>

                    <!-- DIREITA -->
                    <ul class="navbar-nav align-items-center">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-3">

                                <span class="text-white fw-bold">
                                    <i class="bi bi-person-circle"></i>
                                    @User.Identity.Name
                                </span>

                            </li>

                            <li class="nav-item">
                                <a class="btn btn-danger btn-lg rounded-pill px-4 shadow"
                                       asp-controller="Usuario"
                                       asp-action="Sair">

                                    <i class="bi bi-box-arrow-right"></i>
                                    Sair

                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">

                                <a class="btn btn-primary btn-login-custom shadow-lg"
                                       asp-controller="Usuario"
                                       asp-action="Logar">

                                    <i class="bi bi-person-lock me-2"></i>
                                    Entrar

                                </a>

                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <main class="container pb-3">

        @RenderBody()

    </main>

    <footer class="footer bg-white border-top">

        <div class="container text-center py-3 text-muted">

            &copy; @DateTime.Now.Year -
            ProjetoExemploTop -
            <a asp-controller="Home"
                   asp-action="Privacy">

                Privacidade

            </a>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>